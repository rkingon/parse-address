{
  "name": "@rkingon/parse-address",
  "version": "0.0.2",
  "description": "US street address parser. Modern TypeScript rebuild of parse-address (Geo::StreetAddress::US).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "address",
    "parser",
    "street",
    "US",
    "geo",
    "Geo::StreetAddress::US",
    "typescript"
  ],
  "author": "Roi Kingon <rkingon@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rkingon/parse-address.git"
  },
  "homepage": "https://github.com/rkingon/parse-address#readme",
  "bugs": {
    "url": "https://github.com/rkingon/parse-address/issues"
  },
  "dependencies": {
    "xregexp": "^5.1.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
